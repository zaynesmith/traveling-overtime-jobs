  timezone text NOT NULL,
  type USER-DEFINED NOT NULL,
  source USER-DEFINED NOT NULL,
  clock_code_id uuid,
  entered_code_hash text,
  latitude double precision,
  longitude double precision,
  geofence_status USER-DEFINED NOT NULL DEFAULT 'unknown'::geofence_status,
  device_metadata jsonb,
  notes text,
  created_by uuid,
  created_at timestamp with time zone NOT NULL DEFAULT now(),
  CONSTRAINT time_punches_pkey PRIMARY KEY (id),
  CONSTRAINT time_punches_pay_period_id_fkey FOREIGN KEY (pay_period_id) REFERENCES public.pay_periods(id),
  CONSTRAINT time_punches_clock_code_id_fkey FOREIGN KEY (clock_code_id) REFERENCES public.time_clock_codes(id),
  CONSTRAINT time_punches_employer_id_fkey FOREIGN KEY (employer_id) REFERENCES public.employerprofile(id),
  CONSTRAINT time_punches_jobseeker_id_fkey FOREIGN KEY (jobseeker_id) REFERENCES public.jobseekerprofile(id),
  CONSTRAINT time_punches_project_id_fkey FOREIGN KEY (project_id) REFERENCES public.projects(id),
  CONSTRAINT time_punches_job_order_id_fkey FOREIGN KEY (job_order_id) REFERENCES public.job_orders(id),
  CONSTRAINT time_punches_assignment_id_fkey FOREIGN KEY (assignment_id) REFERENCES public.job_order_assignments(id)
);
CREATE TABLE public.trades (
  id uuid NOT NULL DEFAULT gen_random_uuid(),
  name text NOT NULL UNIQUE,
  created_at timestamp with time zone DEFAULT now(),
  CONSTRAINT trades_pkey PRIMARY KEY (id)
);
CREATE TABLE public.user (
  id uuid NOT NULL DEFAULT gen_random_uuid(),
  email text NOT NULL UNIQUE,
  passwordhash text NOT NULL,
  role text DEFAULT 'jobseeker'::text,
  created_at timestamp without time zone NOT NULL DEFAULT now(),
  updated_at timestamp without time zone NOT NULL DEFAULT now(),
  is_admin boolean NOT NULL DEFAULT false,
  CONSTRAINT user_pkey PRIMARY KEY (id)
);
